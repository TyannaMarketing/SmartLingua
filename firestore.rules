rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User Profile Rules
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && 
        request.resource.data.keys().hasAll(['uid', 'email']) &&
        request.resource.data.uid == request.auth.uid;
      allow update: if isOwner(userId) && 
        request.resource.data.uid == existingData().uid;
      
      function existingData() { return resource.data; }

      // Custom Words Rules
      match /customWords/{wordId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(wordId);
        allow update: if isOwner(userId) && isValidId(wordId);
        allow delete: if isOwner(userId);
      }

      // Study Logs Rules
      match /studyLogs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) && isValidId(logId);
        allow update: if isOwner(userId) && isValidId(logId);
      }
    }

    // Payment Requests Rules
    match /payment_requests/{requestId} {
      allow create: if isSignedIn() && 
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow read, update, delete: if false; // Only admin can see these in Firebase Console
    }
  }
}
